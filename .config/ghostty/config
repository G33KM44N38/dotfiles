background-opacity = 1
background-blur = false
minimum-contrast = 7
# tmux uses many Alt-based bindings; force macOS Option to act as Alt.
macos-option-as-alt = true
# Send explicit Meta sequences for tmux worktree picker shortcuts.
keybind = alt+o=text:\x1bo
keybind = alt+shift+o=text:\x1bO
keybind = cmd+shift+z=toggle_split_zoom
keybind = alt+u=unbind
keybind = alt+i=unbind
keybind = alt+y=unbind
theme = light:Dayfox,dark:TokyoNight Night
