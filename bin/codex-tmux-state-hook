#!/usr/bin/env bash

set -euo pipefail

event=""
while [ $# -gt 0 ]; do
	case "$1" in
		--event)
			event="${2:-}"
			shift 2
			;;
		*)
			shift
			;;
	esac
done

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/tmux-thread-picker/codex-hooks"
mkdir -p "$state_dir"
index_file="${XDG_STATE_HOME:-$HOME/.local/state}/tmux-thread-picker/codex-hook-states.tsv"
timeout_bin="$(command -v gtimeout 2>/dev/null || command -v timeout 2>/dev/null || true)"

payload="$(cat)"
now="$(date +%s)"
cwd="${PWD:-}"

payload_cwd="$(printf '%s' "$payload" | perl -MJSON::PP -0777 -ne '
	eval {
		my $data = decode_json($_);
		for my $key (qw(cwd current_dir working_directory workspace project_dir)) {
			my $value = $data->{$key};
			if (defined $value && !ref($value) && length $value) {
				print "$value\n";
				last;
			}
		}
	};
' 2>/dev/null || true)"

[ -n "$payload_cwd" ] && cwd="$payload_cwd"
[ -n "$cwd" ] || exit 0

if command -v git >/dev/null 2>&1; then
	if [ -n "$timeout_bin" ]; then
		root="$("$timeout_bin" 0.5 git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || true)"
	else
		root="$(git -C "$cwd" rev-parse --show-toplevel 2>/dev/null || true)"
	fi
	[ -n "$root" ] && cwd="$root"
fi

case "$event" in
	SessionStart|UserPromptSubmit|PostToolUse)
		state="running"
		;;
	PermissionRequest)
		state="attention"
		;;
	Stop|SubagentStop)
		state="done"
		;;
	*)
		state="unknown"
		;;
esac

key="$(printf '%s' "$cwd" | shasum -a 256 | awk '{print $1}')"
state_file="$state_dir/$key.tsv"
raw_file="$state_dir/$key.json"
tmp_file="$state_file.$$"

printf '%s\t%s\t%s\t%s\n' "$cwd" "$state" "$event" "$now" >"$tmp_file"
mv "$tmp_file" "$state_file"
printf '%s\n' "$payload" >"$raw_file" 2>/dev/null || true

index_tmp="$index_file.$$"
awk -F '\t' -v cwd="$cwd" '$1 != cwd' "$index_file" 2>/dev/null >"$index_tmp" || true
printf '%s\t%s\t%s\t%s\n' "$cwd" "$state" "$event" "$now" >>"$index_tmp"
mv "$index_tmp" "$index_file"

picker="$HOME/.dotfiles/bin/tmux-thread-picker.sh"
if [ -x "$picker" ]; then
	if [ -n "$timeout_bin" ]; then
		"$timeout_bin" 1 "$picker" --notify-fzf >/dev/null 2>&1 || true
	else
		"$picker" --notify-fzf >/dev/null 2>&1 || true
	fi
fi
