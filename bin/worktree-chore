#!/usr/bin/env bash
set -euo pipefail

# -------- config --------
PROTECTED_BRANCHES_REGEX='^(main|release)$'  # add master if needed: '^(main|release|master)$'
DRY_RUN=false
YES=false
AUTO_PULL=true
export GIT_PAGER=cat

if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'
  C_BRANCH=$'\033[38;5;39m'
else
  C_RESET=""
  C_BRANCH=""
fi

color_branch() {
  printf "%s%s%s" "$C_BRANCH" "$1" "$C_RESET"
}

usage() {
  cat <<'EOF'
Usage: worktree-cleanup.sh [--dry-run|-n] [--yes|-y] [--no-pull] [--help|-h]

Cleans up git worktrees:
- SAFE REMOVE: HEAD already merged into origin/main|origin/release
- BEHIND: can auto pull --rebase
- UNPUSHED: local commits not on upstream
- ATTENTION: uncommitted/untracked, diverged, detached, unreadable, no upstream
- KEEP: unique work

Options:
  -n, --dry-run   Show actions without changing anything
  -y, --yes       Do not ask for confirmation
  --no-pull       Do not auto pull behind branches
  -h, --help      Show help
EOF
}

# -------- args --------
while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--dry-run) DRY_RUN=true; shift ;;
    -y|--yes) YES=true; shift ;;
    --no-pull) AUTO_PULL=false; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1"; usage; exit 1 ;;
  esac
done

# -------- preflight --------
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: run inside a git repository/worktree"
  exit 1
fi

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
repo_cwd="$(pwd)"

echo "🧹 worktree cleanup  (mode: $($DRY_RUN && echo DRY-RUN || echo LIVE))"

# -------- fetch --------
if $DRY_RUN; then
  git fetch --all --prune --dry-run >/dev/null 2>&1 || true
else
  git fetch --all --prune >/dev/null 2>&1 || true
fi

# -------- helper: list worktrees robustly --------
# Emits: path<TAB>branch_name (branch_name can be empty for detached)
list_worktrees() {
  git worktree list --porcelain |
    awk '
      $1=="worktree"{path=$2}
      $1=="bare"{path=""; next}
      $1=="branch"{
        b=$2
        sub("^refs/heads/","",b)
        sub("^refs/remotes/","",b)
        print path "\t" b
      }
      $1=="detached"{
        print path "\t" "(detached)"
      }
    '
}

# -------- plan --------
safe_rows=()
behind_rows=()
unpushed_rows=()
attention_rows=()
keep_rows=()
safe_count=0
behind_count=0
unpushed_count=0
attention_count=0
keep_count=0

record_row() {
  local bucket="$1"
  local row="$2"

  case "$bucket" in
    safe)
      safe_rows+=("$row")
      safe_count=$((safe_count + 1))
      ;;
    behind)
      behind_rows+=("$row")
      behind_count=$((behind_count + 1))
      ;;
    unpushed)
      unpushed_rows+=("$row")
      unpushed_count=$((unpushed_count + 1))
      ;;
    attention)
      attention_rows+=("$row")
      attention_count=$((attention_count + 1))
      ;;
    keep)
      keep_rows+=("$row")
      keep_count=$((keep_count + 1))
      ;;
  esac
}

while IFS=$'\t' read -r wt_path wt_branch; do
  [[ -z "${wt_path:-}" ]] && continue
  [[ ! -d "$wt_path" ]] && continue

  if ! cd "$wt_path" 2>/dev/null; then
    record_row attention "$wt_path|$wt_branch|attention|unreadable"
    continue
  fi

  # Determine branch reliably
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  if [[ "$branch" == "HEAD" || -z "$branch" ]]; then
    record_row attention "$wt_path|(detached)|attention|detached"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  fi

  # Protected branches: keep
  if [[ "$branch" =~ $PROTECTED_BRANCHES_REGEX ]]; then
    record_row keep "$wt_path|$branch|keep|protected"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  fi

  # Any local change at all (tracked, staged, deleted, untracked): attention
  if [[ -n "$(git status --porcelain --untracked-files=normal 2>/dev/null)" ]]; then
    record_row attention "$wt_path|$branch|attention|local_changes"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  fi

  # Check whether HEAD is already contained in a protected remote branch
  merged_into=""
  for target in main release; do
    if git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$target"; then
      if git merge-base --is-ancestor HEAD "origin/$target" 2>/dev/null; then
        merged_into="$target"
        break
      fi
    fi
  done

  # Resolve actual upstream if configured; otherwise fall back to origin/<branch> if it exists
  upstream_ref="$(git rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)"
  compare_ref=""
  if [[ -n "$upstream_ref" ]]; then
    compare_ref="$upstream_ref"
  elif git -C "$repo_root" show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    compare_ref="origin/$branch"
  fi

  ahead=0
  behind=0
  if [[ -n "$compare_ref" ]]; then
    ahead="$(git rev-list --count "${compare_ref}..HEAD" 2>/dev/null || echo 0)"
    behind="$(git rev-list --count "HEAD..${compare_ref}" 2>/dev/null || echo 0)"
  fi

  # SAFE only when HEAD is already merged into origin/main or origin/release
  if [[ -n "$merged_into" ]]; then
    record_row safe "$wt_path|$branch|safe|merged|$merged_into"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  fi

  # If there is no upstream to compare against and HEAD is not merged into a protected branch,
  # do NOT assume it's safe.
  if [[ -z "$compare_ref" ]]; then
    record_row attention "$wt_path|$branch|attention|no_upstream"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  fi

  # Ahead/behind relative to actual upstream
  if [[ "$ahead" -gt 0 && "$behind" -gt 0 ]]; then
    record_row attention "$wt_path|$branch|attention|diverged|$ahead|$behind|$compare_ref"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  elif [[ "$ahead" -gt 0 ]]; then
    record_row unpushed "$wt_path|$branch|unpushed|unpushed|$ahead|$compare_ref"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  elif [[ "$behind" -gt 0 ]]; then
    record_row behind "$wt_path|$branch|behind|behind|$behind|$compare_ref"
    cd "$repo_cwd" >/dev/null 2>&1 || true
    continue
  fi

  # sync with upstream and clean => safe to remove
  record_row safe "$wt_path|$branch|safe|synced_clean|$compare_ref"
  cd "$repo_cwd" >/dev/null 2>&1 || true
done < <(list_worktrees)

# -------- summarize --------
echo

if [[ "${#safe_rows[@]}" -gt 0 ]]; then
  echo "✅ SAFE TO REMOVE"
  for row in "${safe_rows[@]}"; do
    IFS='|' read -r path branch _ reason extra <<<"$row"
    case "$reason" in
      merged) echo "  • $(color_branch "$branch")  (merged into origin/$extra)";;
      synced_clean) echo "  • $(color_branch "$branch")  (clean and synced with ${extra:-upstream})";;
      *) echo "  • $(color_branch "$branch")";;
    esac
    echo "    $path"
  done
  echo
fi

if [[ "${#behind_rows[@]}" -gt 0 ]]; then
  echo "🔄 BEHIND (can pull --rebase)"
  for row in "${behind_rows[@]}"; do
    IFS='|' read -r path branch _ _ count compare_ref <<<"$row"
    echo "  • $(color_branch "$branch")  ($count behind ${compare_ref:-upstream})"
    echo "    $path"
  done
  echo
fi

if [[ "${#unpushed_rows[@]}" -gt 0 ]]; then
  echo "📤 UNPUSHED COMMITS"
  for row in "${unpushed_rows[@]}"; do
    IFS='|' read -r path branch _ _ count compare_ref <<<"$row"
    echo "  • $(color_branch "$branch")  ($count commit(s) not pushed to ${compare_ref:-upstream})"
    echo "    $path"
  done
  echo
fi

if [[ "${#attention_rows[@]}" -gt 0 ]]; then
  echo "⚠️  ATTENTION (manual review)"
  for row in "${attention_rows[@]}"; do
    IFS='|' read -r path branch _ reason a b c <<<"$row"
    case "$reason" in
      local_changes) echo "  • $(color_branch "$branch")  (local changes: tracked/staged/untracked)";;
      diverged) echo "  • $(color_branch "$branch")  (diverged from ${c:-upstream}: $a ahead, $b behind)";;
      detached) echo "  • (detached)";;
      unreadable) echo "  • $(color_branch "$branch")  (cannot read path)";;
      no_upstream) echo "  • $(color_branch "$branch")  (no upstream configured / remote-tracking ref missing)";;
      *) echo "  • $(color_branch "$branch")  ($reason)";;
    esac
    echo "    $path"
  done
  echo
fi

if [[ "${#keep_rows[@]}" -gt 0 ]]; then
  echo "ℹ️  KEEP"
  for row in "${keep_rows[@]}"; do
    IFS='|' read -r path branch _ why extra <<<"$row"
    case "$why" in
      protected) echo "  • $(color_branch "$branch")  (protected)";;
      unique) echo "  • $(color_branch "$branch")  (unique)";;
      *) echo "  • $(color_branch "$branch")  ($why)";;
    esac
    echo "    $path"
  done
  echo
fi

if [[ "$safe_count" -eq 0 && "$behind_count" -eq 0 ]]; then
  echo "✓ Nothing to do automatically."
  exit 0
fi

# -------- confirm --------
if ! $YES && ! $DRY_RUN; then
  echo "Ready to:"
  [[ "$safe_count" -gt 0 ]] && echo "  • remove $safe_count worktree(s)"
  [[ "$behind_count" -gt 0 ]] && $AUTO_PULL && echo "  • pull $behind_count worktree(s)"
  echo
  read -r -p "Proceed? [y/N] " ans
  [[ "$ans" =~ ^[Yy]([Ee][Ss])?$ ]] || { echo "Aborted."; exit 0; }
fi

# -------- actions --------
if [[ "$safe_count" -gt 0 ]]; then
  echo "🗑️  Removing safe worktrees..."
  for row in "${safe_rows[@]}"; do
    IFS='|' read -r path branch _ _ _ <<<"$row"
    if $DRY_RUN; then
      echo "  [DRY RUN] git worktree remove --force \"$path\""
      echo "  [DRY RUN] git branch -d \"$branch\""
      continue
    fi

    git -C "$repo_root" worktree remove --force "$path" >/dev/null 2>&1 \
      && echo "  ✓ removed $(color_branch "$branch")" \
      || echo "  ⚠️  failed to remove $(color_branch "$branch")"

    # delete local branch if possible (will fail if not fully merged)
    git -C "$repo_root" branch -d "$branch" >/dev/null 2>&1 || true
  done
  echo
fi

if [[ "$behind_count" -gt 0 && "$AUTO_PULL" == true ]]; then
  echo "⬇️  Pulling behind worktrees..."
  for row in "${behind_rows[@]}"; do
    IFS='|' read -r path branch _ _ _ compare_ref <<<"$row"
    if $DRY_RUN; then
      echo "  [DRY RUN] (cd \"$path\" && git pull --rebase)"
      continue
    fi

    git -C "$path" pull --rebase >/dev/null 2>&1 \
      && echo "  ✓ pulled $(color_branch "$branch")" \
      || echo "  ⚠️  failed pull $(color_branch "$branch")"
  done
  echo
fi

# -------- prune --------
if $DRY_RUN; then
  echo "[DRY RUN] git worktree prune"
else
  git -C "$repo_root" worktree prune >/dev/null 2>&1 || true
fi

echo "✓ Done."
