#!/bin/bash

# Required parameters:
# @raycast.schemaVersion 1
# @raycast.title pc_clean
# @raycast.mode compact

# Optional parameters:
# @raycast.icon 🧹

# Documentation:
# @raycast.description Optimized system and development environment cleanup with progress UI
# @raycast.author me

# -------------------------
# UI Functions
# -------------------------

# Terminal colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
RESET='\033[0m'

FULL_CLEAN=false
SKIP_PYTHON=false
ANALYZE_ONLY=false
DRY_RUN=false
SKIP_DOCKER=false
SKIP_BREW=false
SKIP_XCODE=false
INCLUDE_BREW_CASKS=false
SIM_RUNTIME_RETENTION_DAYS=30
CHOOSE_SIM_RUNTIME=false
DUA_BIN=""
WIFI_DNS_BEFORE=""

# Print colored header
print_header() {
  echo -e "\n${BLUE}========================================${RESET}"
  echo -e "${CYAN}$1${RESET}"
  echo -e "${BLUE}========================================${RESET}\n"
}

# Success message
success() {
  echo -e "${GREEN}✓${RESET} $1"
}

# Error message
error() {
  echo -e "${RED}✗${RESET} $1"
}

warn() {
  echo -e "${YELLOW}!${RESET} $1"
}

# Info message
info() {
  echo -e "${YELLOW}→${RESET} $1"
}

# Processing message with spinner
process_spinner() {
  local pid=$1
  local message=$2
  local spin='-\|/'
  local i=0
  
  echo -ne "${YELLOW}→${RESET} $message "
  
  while kill -0 $pid 2>/dev/null; do
    i=$(( (i+1) % 4 ))
    echo -ne "\b${spin:$i:1}"
    sleep 0.1
  done
  
  wait $pid
  if [ $? -eq 0 ]; then
    echo -e "\b${GREEN}✓${RESET}"
  else
    echo -e "\b${RED}✗${RESET}"
  fi
}

# Progress bar for multi-step operations
show_progress() {
  local current=$1
  local total=$2
  local title=$3
  local percent=$((current * 100 / total))
  local progress=$((current * 40 / total))
  
  printf "${MAGENTA}[%-40s]${RESET} %3d%% %s\r" "$(printf '█%.0s' $(seq 1 $progress))" "$percent" "$title"
}

# -------------------------
# Optimization Functions
# -------------------------

# Check if command exists
command_exists() {
  command -v "$1" &> /dev/null
}

init_environment() {
  if command_exists dua; then
    DUA_BIN="$(command -v dua)"
  elif [ -x /opt/homebrew/bin/dua ]; then
    DUA_BIN="/opt/homebrew/bin/dua"
  fi
}

print_usage() {
  cat <<EOF
Usage: pc_clean [options]

Cleanup and analyze development-heavy storage on macOS.

Options:
  --analyze                     Print a storage report without deleting anything
  --choose-sim-runtime          Interactively choose installed simulator runtime(s) to delete
  --dry-run                     Show destructive actions without executing them
  --full                        Run more aggressive cleanup steps
  --include-brew-casks          Also upgrade Homebrew casks (disabled by default)
  --skip-python                 Skip Python cache cleanup
  --skip-brew                   Skip Homebrew maintenance
  --skip-docker                 Skip Docker cleanup
  --skip-xcode                  Skip Xcode / Simulator cleanup
  --sim-runtime-days <days>     Retention threshold for simulator runtimes in full mode
  -h, --help                    Show this help

Examples:
  pc_clean --analyze
  pc_clean --choose-sim-runtime
  pc_clean --include-brew-casks
  pc_clean --dry-run --full
  pc_clean --full --sim-runtime-days 14
EOF
}

run_destructive() {
  local description="$1"
  shift

  if [ "$DRY_RUN" = true ]; then
    info "[dry-run] $description"
    printf '    %q' "$@"
    printf '\n'
    return 0
  fi

  "$@"
}

run_with_spinner() {
  local message="$1"
  shift

  if [ "$DRY_RUN" = true ]; then
    info "[dry-run] $message"
    printf '    %q' "$@"
    printf '\n'
    return 0
  fi

  "$@" &>/dev/null &
  process_spinner $! "$message"
}

run_with_spinner_logged() {
  local message="$1"
  local logfile="$2"
  shift 2

  if [ "$DRY_RUN" = true ]; then
    info "[dry-run] $message"
    printf '    %q' "$@"
    printf '\n'
    return 0
  fi

  "$@" >"$logfile" 2>&1 &
  process_spinner $! "$message"
}

print_log_excerpt() {
  local logfile="$1"
  local lines="${2:-20}"
  [ -f "$logfile" ] || return 0

  info "Last ${lines} log lines:"
  tail -n "$lines" "$logfile" | sed 's/^/    /'
}

print_brew_cask_recovery_hints() {
  local logfile="$1"
  local broken_casks=()
  local line

  while IFS= read -r line; do
    broken_casks+=("${line%%:*}")
  done < <(grep -E '^[A-Za-z0-9@._+-]+: It seems the App source ' "$logfile" 2>/dev/null)

  if [ ${#broken_casks[@]} -eq 0 ]; then
    return 0
  fi

  warn "One or more Homebrew casks are in a broken installed state."
  info "This usually means the app bundle was removed or renamed outside Homebrew."
  for cask in "${broken_casks[@]}"; do
    info "To repair $cask: brew uninstall --cask --force $cask"
    info "Then reinstall only if you still want it: brew install --cask $cask"
  done
}

flush_dns_cache() {
  dscacheutil -flushcache 2>/dev/null || true
  killall -HUP mDNSResponder 2>/dev/null || true
}

github_dns_resolves() {
  local host

  for host in github.com api.github.com; do
    if ! dscacheutil -q host -a name "$host" >/dev/null 2>&1; then
      return 1
    fi
  done

  return 0
}

set_hotspot_dns_if_github_is_broken() {
  if ! command_exists networksetup; then
    return 1
  fi

  if github_dns_resolves; then
    return 0
  fi

  if [ -n "$WIFI_DNS_BEFORE" ] && [ "$WIFI_DNS_BEFORE" != "There aren't any DNS Servers set on Wi-Fi." ]; then
    warn "GitHub DNS resolution broke; restoring previous Wi-Fi DNS"
    # shellcheck disable=SC2086
    run_destructive "Restore previous Wi-Fi DNS" networksetup -setdnsservers Wi-Fi $WIFI_DNS_BEFORE
    if [ "$DRY_RUN" = false ]; then
      flush_dns_cache
      if github_dns_resolves; then
        return 0
      fi
    fi
  fi

  warn "GitHub DNS resolution broke; applying hotspot-safe Wi-Fi DNS"
  run_destructive "Set Wi-Fi DNS for hotspot GitHub access" \
    networksetup -setdnsservers Wi-Fi 1.1.1.1 8.8.8.8
  if [ "$DRY_RUN" = true ]; then
    return 0
  fi

  flush_dns_cache
  github_dns_resolves
}

remember_wifi_dns() {
  if command_exists networksetup; then
    WIFI_DNS_BEFORE="$(networksetup -getdnsservers Wi-Fi 2>/dev/null || true)"
  fi
}

run_external_cleanup_tools() {
  local tool

  # Keep these Homebrew cleanup tools in the main flow, but guard DNS after each
  # one because hotspot-provided resolvers have broken GitHub lookups before.
  for tool in mole mac-cleanup; do
    if command_exists "$tool"; then
      info "Running $tool"
      run_with_spinner "$tool" "$tool"
      set_hotspot_dns_if_github_is_broken || warn "GitHub DNS still does not resolve after $tool"
    else
      warn "Skipping $tool: command not found"
    fi
  done
}

# Run tasks in parallel
run_parallel() {
  local tasks=("$@")
  local pids=()
  
  for task in "${tasks[@]}"; do
    eval "$task" &
    pids+=($!)
  done
  
  # Wait for all background processes to complete
  for pid in "${pids[@]}"; do
    wait $pid
  done
}

# Only clean directories if they exist and are not empty
clean_directory_if_needed() {
  local dir="$1"
  if [ -d "$dir" ] && [ "$(ls -A "$dir" 2>/dev/null)" ]; then
    info "Cleaning: $dir"
    if [ "$DRY_RUN" = true ]; then
      info "[dry-run] Would remove contents of $dir"
    else
      find "$dir" -mindepth 1 -maxdepth 1 -exec rm -rf {} + 2>/dev/null
      success "Cleaned $dir"
    fi
  fi
}

report_path_size() {
  local path="$1"
  [ -e "$path" ] || return 0
  du -sh "$path" 2>/dev/null
}

list_runtime_entries() {
  xcrun simctl runtime list -v 2>/dev/null | awk '
    /^iOS / {
      name=$0
      sub(/ - [A-F0-9-]+$/, "", name)
      id=$NF
      version=name
      state=""
      lastUsed=""
      size=""
      next
    }
    /State:/ { sub(/^[[:space:]]*State: /, "", $0); state=$0; next }
    /Last Used At:/ { sub(/^[[:space:]]*Last Used At: /, "", $0); lastUsed=$0; next }
    /Size:/ {
      sub(/^[[:space:]]*Size: /, "", $0)
      size=$0
      printf "%s|%s|%s|%s|%s\n", id, version, state, lastUsed, size
    }
  '
}

choose_sim_runtime_to_delete() {
  print_header "Simulator Runtime Selection"

  if ! command_exists xcrun; then
    error "xcrun is not available. Install Xcode command line tools or Xcode first."
    return 1
  fi

  local runtime_lines=()
  while IFS= read -r line; do
    [ -n "$line" ] && runtime_lines+=("$line")
  done < <(list_runtime_entries)

  if [ ${#runtime_lines[@]} -eq 0 ]; then
    info "No installed simulator runtimes found"
    return 0
  fi

  echo "Installed runtimes:"
  local idx=1
  local line runtime_id runtime_name runtime_state runtime_last_used runtime_size
  for line in "${runtime_lines[@]}"; do
    IFS='|' read -r runtime_id runtime_name runtime_state runtime_last_used runtime_size <<< "$line"
    printf "  %d) %s [%s, last used: %s, size: %s]\n" \
      "$idx" "$runtime_name" "$runtime_state" "${runtime_last_used:-unknown}" "${runtime_size:-unknown}"
    idx=$((idx + 1))
  done
  echo "  a) Delete all listed runtimes"
  echo "  q) Cancel"
  echo
  printf "Choose runtime(s) to delete: "

  local selection
  IFS= read -r selection

  case "$selection" in
    q|Q|"")
      info "Runtime deletion cancelled"
      return 0
      ;;
    a|A)
      for line in "${runtime_lines[@]}"; do
        IFS='|' read -r runtime_id runtime_name runtime_state runtime_last_used runtime_size <<< "$line"
        info "Deleting runtime: $runtime_name"
        run_with_spinner "Deleting $runtime_name" xcrun simctl runtime delete "$runtime_id"
      done
      return 0
      ;;
  esac

  local selections=()
  local token
  for token in ${selection//,/ }; do
    if [[ "$token" =~ ^[0-9]+$ ]] && [ "$token" -ge 1 ] && [ "$token" -le ${#runtime_lines[@]} ]; then
      selections+=("$token")
    else
      error "Invalid selection: $token"
      info "Use numbers from the list, separated by spaces or commas"
      return 1
    fi
  done

  if [ ${#selections[@]} -eq 0 ]; then
    info "No runtimes selected"
    return 0
  fi

  local seen=" "
  for token in "${selections[@]}"; do
    if [[ "$seen" == *" $token "* ]]; then
      continue
    fi
    seen="${seen}${token} "
    line="${runtime_lines[$((token - 1))]}"
    IFS='|' read -r runtime_id runtime_name runtime_state runtime_last_used runtime_size <<< "$line"
    info "Deleting runtime: $runtime_name"
    run_with_spinner "Deleting $runtime_name" xcrun simctl runtime delete "$runtime_id"
  done
}

print_storage_report() {
  print_header "Storage Report"

  info "Disk usage overview"
  df -h / /System/Volumes/Data 2>/dev/null
  echo

  if [ -n "$DUA_BIN" ]; then
    info "Largest top-level buckets"
    "$DUA_BIN" aggregate -f gib \
      "$HOME/Library" \
      "$HOME/coding" \
      "$HOME/Pictures" \
      /opt/homebrew \
      /Applications 2>/dev/null | sort -h
    echo
  else
    warn "dua not found. Falling back to du summaries."
  fi

  info "High-value cleanup targets"
  for path in \
    "$HOME/Library/Developer/Xcode/DerivedData" \
    "$HOME/Library/Developer/CoreSimulator/Devices" \
    "/Library/Developer/CoreSimulator/Volumes" \
    "$HOME/Library/Containers/com.docker.docker" \
    "$HOME/Library/Caches" \
    "$HOME/Library/Application Support" \
    /opt/homebrew/Cellar \
    /Applications/Xcode.app \
    /Applications/Docker.app; do
    report_path_size "$path"
  done | sort -h
  echo

  if command_exists xcrun; then
    info "Installed simulator runtimes"
    xcrun simctl list runtimes 2>/dev/null || warn "simctl is available but runtimes could not be listed"
    echo
  fi

  if command_exists docker; then
    info "Docker disk usage"
    docker system df 2>/dev/null || warn "Docker is installed but not responding"
    echo
  fi
}

# -------------------------
# Main Cleanup Functions
# -------------------------

# Run system memory and cache cleanup
clean_system_memory() {
  print_header "System Memory Cleanup"
  
  if command_exists sudo && command_exists purge; then
    info "Purging system memory..."
    run_with_spinner "Purging system memory" sudo purge
  else
    warn "Skipping memory purge: 'purge' is not available on this macOS version"
  fi
}

# Run brew cleanup in optimized way
clean_homebrew() {
  print_header "Homebrew Cleanup"
  
  if [ "$SKIP_BREW" = true ]; then
    info "Homebrew cleanup skipped (--skip-brew flag used)"
    return
  fi

  if ! command_exists brew; then
    warn "Skipping Homebrew cleanup: 'brew' is not installed"
    return
  fi

  info "Updating and cleaning Homebrew packages..."
  local brew_log_dir
  brew_log_dir="$(mktemp -d "${TMPDIR:-/tmp}/pc_clean_brew.XXXXXX")"
  info "Homebrew logs: $brew_log_dir"

  run_with_spinner_logged "Updating Homebrew" "$brew_log_dir/update.log" brew update

  if ! run_with_spinner_logged "Upgrading formulae" "$brew_log_dir/upgrade-formula.log" brew upgrade --formula; then
    error "Homebrew formula upgrade failed"
    print_log_excerpt "$brew_log_dir/upgrade-formula.log"
  fi

  if [ "$INCLUDE_BREW_CASKS" = true ]; then
    if ! run_with_spinner_logged "Upgrading casks" "$brew_log_dir/upgrade-cask.log" brew upgrade --cask; then
      error "Homebrew cask upgrade failed"
      print_log_excerpt "$brew_log_dir/upgrade-cask.log"
      print_brew_cask_recovery_hints "$brew_log_dir/upgrade-cask.log"
    fi
  else
    info "Skipping Homebrew cask upgrades by default"
    info "Use --include-brew-casks to opt in"
  fi

  if ! run_with_spinner_logged "Cleaning old versions" "$brew_log_dir/cleanup.log" brew cleanup --prune=all; then
    error "Homebrew cleanup failed"
    print_log_excerpt "$brew_log_dir/cleanup.log"
  fi

  if ! run_with_spinner_logged "Removing unneeded dependencies" "$brew_log_dir/autoremove.log" brew autoremove; then
    error "Homebrew autoremove failed"
    print_log_excerpt "$brew_log_dir/autoremove.log"
  fi

  if [ "$FULL_CLEAN" = true ]; then
    local brew_cache
    brew_cache="$(brew --cache 2>/dev/null)"
    if [ -n "$brew_cache" ] && [ -d "$brew_cache" ]; then
      clean_directory_if_needed "$brew_cache"
    fi
  fi

  success "Homebrew maintenance complete"
}

# Clean development related directories
clean_dev_directories() {
  print_header "Development Environment Cleanup"
  
  # Find old node_modules directories (only in user's projects, not system dirs)
  local project_roots=("$HOME/coding" "$HOME/Projects" "$HOME/dev")

  if [ -d "$HOME/coding" ]; then
    info "Removing old node_modules directories..."
    if [ "$DRY_RUN" = true ]; then
      find "$HOME/coding" -name "node_modules" -type d -mtime +120 2>/dev/null | sed 's/^/    /'
    else
      find "$HOME/coding" -name "node_modules" -type d -mtime +120 -prune -exec rm -rf {} \; 2>/dev/null &
      process_spinner $! "Cleaning old node_modules (older than 120 days)"
    fi
  fi
  
  # Remove Python cache (optimize the find command)
  if [ "$SKIP_PYTHON" = false ] && (command_exists python3 || command_exists python); then
    info "Cleaning Python cache..."
    
    # Define Python project directories, prioritizing ~/coding
    python_dirs=()
    # Add user's main coding directory first
    if [ -d "$HOME/coding" ]; then
      python_dirs+=("$HOME/coding")
    fi
    
    # Add other common directories as fallback
    for dir in "$HOME/Projects" "$HOME/code" "$HOME/python" "$HOME/development" "$HOME/dev"; do
      if [ -d "$dir" ] && [ "$dir" != "$HOME/coding" ]; then
        python_dirs+=("$dir")
      fi
    done
    
    if [ ${#python_dirs[@]} -gt 0 ]; then
      # Use a more targeted approach with better feedback
      info "Targeting directories: ${python_dirs[*]}"
      
      # Use a more efficient approach with a timeout
      (
        for dir in "${python_dirs[@]}"; do
          find "$dir" -name "__pycache__" -type d -prune -exec rm -rf {} \; 2>/dev/null
        done
      ) & PID=$!
      
      # Add a shorter timeout (15 seconds should be plenty for targeted directories)
      (
        sleep 15
        if ps -p $PID > /dev/null; then
          kill $PID 2>/dev/null
          wait $PID 2>/dev/null
          echo -e "\b${YELLOW}⚠${RESET} (timed out)"
        fi
      ) & TIMEOUT_PID=$!
      
      process_spinner $PID "Cleaning Python cache (15s max)"
      kill $TIMEOUT_PID 2>/dev/null
      wait $TIMEOUT_PID 2>/dev/null
    else
      info "No Python project directories found, skipping cache cleanup"
    fi
  elif [ "$SKIP_PYTHON" = true ]; then
    info "Python cache cleanup skipped (--skip-python flag used)"
  fi
  
  # Run multiple cleanups in parallel for speed
  local parallel_tasks=(
    "clean_directory_if_needed '$HOME/Library/Caches/pip'" 
    "clean_directory_if_needed '$HOME/.npm'" 
    "clean_directory_if_needed '$HOME/.gradle/caches'"
    "clean_directory_if_needed '$HOME/Library/Caches/CocoaPods'"
    "clean_directory_if_needed '$HOME/Library/Developer/Xcode/DerivedData/'"
    "clean_directory_if_needed '$HOME/Library/Developer/Xcode/Archives/'"
    "clean_directory_if_needed '$HOME/Library/Developer/Xcode/iOS DeviceSupport/'"
  )
  
  run_parallel "${parallel_tasks[@]}"
  success "Cache directories cleaned"
}

# Clean Xcode related files
clean_xcode() {
  print_header "Xcode Cleanup"

  if [ "$SKIP_XCODE" = true ]; then
    info "Xcode cleanup skipped (--skip-xcode flag used)"
    return
  fi
  
  # Check if Xcode is installed
  if [ ! -d "/Applications/Xcode.app" ] && [ ! -d "$HOME/Library/Developer" ]; then
    info "Xcode not installed, skipping related cleanup"
    return
  fi

  info "Closing Xcode if running..."
  osascript -e 'quit app "Xcode"' &>/dev/null || true
  sleep 1

  local parallel_tasks=(
    "clean_directory_if_needed '$HOME/Library/Developer/Xcode/DerivedData'"
    "clean_directory_if_needed '$HOME/Library/Developer/Xcode/Archives'"
    "clean_directory_if_needed '$HOME/Library/Caches/com.apple.dt.Xcode'"
  )
  run_parallel "${parallel_tasks[@]}"

  if command_exists xcrun; then
    if [ "$CHOOSE_SIM_RUNTIME" = true ]; then
      choose_sim_runtime_to_delete || return 1
    fi

    run_with_spinner "Deleting unavailable simulator devices" xcrun simctl delete unavailable

    if [ "$FULL_CLEAN" = true ]; then
      run_with_spinner \
        "Deleting simulator runtimes unused for ${SIM_RUNTIME_RETENTION_DAYS} days" \
        xcrun simctl runtime delete --notUsedSinceDays "$SIM_RUNTIME_RETENTION_DAYS"
    else
      if [ "$DRY_RUN" = true ]; then
        run_with_spinner \
          "Previewing simulator runtimes unused for ${SIM_RUNTIME_RETENTION_DAYS} days" \
          xcrun simctl runtime delete --notUsedSinceDays "$SIM_RUNTIME_RETENTION_DAYS" --dry-run
      else
        info "Standard mode keeps installed simulator runtimes"
        info "Use --full to delete runtimes unused for ${SIM_RUNTIME_RETENTION_DAYS} days"
      fi
    fi
  else
    warn "Skipping simulator cleanup: 'xcrun' is not available"
  fi

  success "Xcode cleanup complete"
}

# Clean Docker if installed
clean_docker() {
  print_header "Docker Cleanup"
  
  if [ "$SKIP_DOCKER" = true ]; then
    info "Docker cleanup skipped (--skip-docker flag used)"
    return
  fi

  if ! command_exists docker; then
    info "Docker not installed, skipping cleanup"
    return
  fi

  if ! docker info &>/dev/null; then
    warn "Skipping Docker cleanup: Docker is installed but the daemon is not running"
    info "Start Docker Desktop, then rerun this script for Docker reclamation"
    return
  fi

  info "Docker usage before cleanup"
  docker system df 2>/dev/null || true
  echo

  run_with_spinner "Pruning unused Docker volumes" docker volume prune -f
  run_with_spinner "Pruning Docker system" docker system prune -af --volumes

  info "Docker usage after cleanup"
  docker system df 2>/dev/null || true
  success "Docker cleanup complete"
}

# Clean Rust if installed
clean_rust() {
  print_header "Rust Cleanup"
  
  if ! command_exists cargo; then
    info "Rust not installed, skipping cleanup"
    return
  fi

  local search_root
  search_root="$HOME/coding"
  if [ ! -d "$search_root" ]; then
    search_root="$HOME/Projects"
  fi

  if [ -d "$search_root" ]; then
    info "Cleaning Rust project artifacts under $search_root..."
    find "$search_root" -name "Cargo.toml" -type f -execdir cargo clean \; &>/dev/null &
    process_spinner $! "Cleaning Rust project build artifacts"
  else
    info "No Rust project root found, skipping build artifact cleanup"
  fi

  success "Rust cleanup complete"
}

# Clean Git repositories
clean_git_repos() {
  print_header "Git Repository Cleanup"
  
  if command_exists git; then
    # Process Git repositories more efficiently by targeting specific directories
    local git_dirs=()
    
    local repo_root="$HOME/coding"
    if [ ! -d "$repo_root" ]; then
      repo_root="$HOME/Projects"
    fi

    if [ -d "$repo_root" ]; then
      mapfile -t git_dirs < <(find "$repo_root" -name ".git" -type d -prune 2>/dev/null)
      
      if [ ${#git_dirs[@]} -gt 0 ]; then
        info "Found ${#git_dirs[@]} Git repositories to clean"
        
        local count=0
        local total=${#git_dirs[@]}
        
        for git_dir in "${git_dirs[@]}"; do
          repo_dir="${git_dir%/.git}"
          ((count++))
          
          show_progress $count $total "Cleaning Git repos"
          
          # Clean merged branches (master or main)
          git -C "$repo_dir" branch --merged 2>/dev/null | grep -v "\* \(main\|master\)" | xargs -r git -C "$repo_dir" branch -d &>/dev/null
        done
        
        echo # Add newline after progress bar
        success "Git repositories cleaned"
      else
        info "No Git repositories found"
      fi
    else
      info "No Projects directory found, skipping Git cleanup"
    fi
  else
    info "Git not installed, skipping cleanup"
  fi
}

# Clean system application caches and unused files
clean_system_caches() {
  print_header "System Cache Cleanup"
  
  # Clean download history
  local quarantine_db
  quarantine_db="$(compgen -G "$HOME/Library/Preferences/com.apple.LaunchServices.QuarantineEventsV*" | head -n 1)"
  if [ -n "$quarantine_db" ]; then
    info "Clearing download history..."
    run_with_spinner \
      "Clearing download history" \
      sqlite3 "$quarantine_db" 'delete from LSQuarantineEvent'
  fi
  
  # Clean trash if necessary and user confirms
  if [ -d "$HOME/.Trash" ] && [ "$(ls -A "$HOME/.Trash" 2>/dev/null)" ]; then
    info "Emptying Trash..."
    run_with_spinner "Emptying Trash" rm -rf "$HOME/.Trash"/*
  fi
  
  # Clean various application support directories (in parallel)
  local parallel_tasks=(
    "clean_directory_if_needed '$HOME/Library/Application Support/CrashReporter'"
    "clean_directory_if_needed '$HOME/Library/Application State'"
    "clean_directory_if_needed '$HOME/Library/Caches'"
  )
  
  run_parallel "${parallel_tasks[@]}"
  success "System caches cleaned"
}

clean_uninstalled_app_data() {
  local app_support_dir="$HOME/Library/Application Support"
  local app_locations=("/Applications" "$HOME/Applications")

  print_header "Cleaning uninstalled app data in Application Support"

  # Loop through each folder in Application Support
  find "$app_support_dir" -mindepth 1 -maxdepth 1 -type d | while read -r app_folder; do
    local app_name=$(basename "$app_folder")
    local app_found=false

    # Check if app exists in the common Applications folders
    for loc in "${app_locations[@]}"; do
      # Check for app bundles (.app) with matching name (case-insensitive)
      if ls "$loc"/*.app 2>/dev/null | grep -iq "^$loc/$app_name\.app$"; then
        app_found=true
        break
      fi
    done

    # If not found, delete the app data folder
    if [ "$app_found" = false ]; then
      info "Removing leftover data for uninstalled app: $app_name"
      rm -rf "$app_folder"
      success "Deleted $app_folder"
    fi
  done
}

# -------------------------
# Main Execution
# -------------------------

# Run the main cleanup function
main() {
  init_environment
  
  # Parse command line arguments
  while [ $# -gt 0 ]; do
    case "$1" in
      --analyze)
        ANALYZE_ONLY=true
        ;;
      --choose-sim-runtime)
        CHOOSE_SIM_RUNTIME=true
        ;;
      --dry-run)
        DRY_RUN=true
        ;;
      --full)
        FULL_CLEAN=true
        ;;
      --include-brew-casks)
        INCLUDE_BREW_CASKS=true
        ;;
      --skip-python)
        SKIP_PYTHON=true
        ;;
      --skip-brew)
        SKIP_BREW=true
        ;;
      --skip-docker)
        SKIP_DOCKER=true
        ;;
      --skip-xcode)
        SKIP_XCODE=true
        ;;
      --sim-runtime-days)
        shift
        if [ -z "${1:-}" ] || ! [[ "$1" =~ ^[0-9]+$ ]]; then
          error "Missing or invalid value for --sim-runtime-days"
          print_usage
          exit 1
        fi
        SIM_RUNTIME_RETENTION_DAYS="$1"
        ;;
      -h|--help)
        print_usage
        exit 0
        ;;
      *)
        error "Unknown option: $1"
        print_usage
        exit 1
        ;;
    esac
    shift
  done

  # Clear the screen for a clean start
  clear
  
  # Show a nice banner
  echo -e "${CYAN}"
  echo '  _____   _____    _____  _      _____          _   _ '
  echo ' |  __ \ / ____|  / ____|| |    |  ___|  /\    | \ | |'
  echo ' | |__) | |      | |     | |    | |__   /  \   |  \| |'
  echo ' |  ___/| |      | |     | |    |  __| / /\ \  | . ` |'
  echo ' | |    | |____  | |____ | |___ | |___/ ____ \ | |\  |'
  echo ' |_|     \_____|  \_____||_____||_____/_/    \_\|_| \_|'
  echo -e "${RESET}"
  echo -e "${GREEN}Optimized System Cleanup Tool${RESET}"
  echo -e "${YELLOW}=====================================${RESET}\n"
  
  # Display mode information
  if [ "$ANALYZE_ONLY" = true ]; then
    echo -e "${BLUE}Running in analysis mode only${RESET}\n"
    print_storage_report
    print_header "Analysis Complete"
    echo -e "${GREEN}No cleanup actions were executed.${RESET}\n"
    exit 0
  fi

  remember_wifi_dns
  run_external_cleanup_tools

  if [ "$FULL_CLEAN" = true ]; then
    echo -e "${MAGENTA}Running in FULL cleanup mode${RESET}\n"
  else
    echo -e "${BLUE}Running in standard cleanup mode${RESET}"
    echo -e "${BLUE}Use --full for more aggressive cleaning${RESET}\n"
  fi

  if [ "$DRY_RUN" = true ]; then
    echo -e "${YELLOW}Dry-run mode enabled: destructive actions will be printed, not executed${RESET}\n"
  fi
  
  if [ "$SKIP_PYTHON" = true ]; then
    echo -e "${YELLOW}Skipping Python cache cleanup${RESET}\n"
  fi

  if [ "$CHOOSE_SIM_RUNTIME" = true ]; then
    echo -e "${YELLOW}Interactive simulator runtime selection enabled${RESET}\n"
  fi

  print_storage_report
  
  # Count total steps for progress tracking
  local total_steps=7
  local current_step=0

  # Run cleanup functions with progress tracking
  clean_system_memory
  ((current_step++))
  show_progress $current_step $total_steps "Overall Progress"
  
  clean_homebrew
  ((current_step++))
  show_progress $current_step $total_steps "Overall Progress"
  
  clean_dev_directories
  ((current_step++))
  show_progress $current_step $total_steps "Overall Progress"
  
  clean_xcode
  ((current_step++))
  show_progress $current_step $total_steps "Overall Progress"
  
  clean_docker
  ((current_step++))
  show_progress $current_step $total_steps "Overall Progress"
  
  clean_rust
  ((current_step++))
  show_progress $current_step $total_steps "Overall Progress"
  
  clean_git_repos
  ((current_step++))
  show_progress $current_step $total_steps "Overall Progress"
  
  clean_system_caches
  # clean_uninstalled_app_data
  
  # Final cleanup message
  echo # Add newline after progress bar
  print_header "Cleanup Complete!"
  echo -e "${GREEN}Your system has been cleaned and optimized.${RESET}"
  echo -e "${YELLOW}You may want to restart your system for all changes to take effect.${RESET}\n"
}

# Execute the main function with any passed arguments
main "$@"
